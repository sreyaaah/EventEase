@page "/events"
@rendermode InteractiveServer
@using EventEase.Models

<PageTitle>Events - EventEase</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-0">Upcoming <span class="gradient-text">Events</span></h2>
            <p class="text-muted mb-0">Discover and manage your next experiences</p>
        </div>
        <div class="w-25">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input @bind="searchTerm" @bind:event="oninput" 
                       class="form-control border-start-0 ps-0" 
                       placeholder="Search events..." />
            </div>
        </div>
    </div>

    @if (FilteredEvents.Count == 0)
    {
        <div class="text-center py-5 animate-fade-in">
            <i class="bi bi-calendar-x display-1 text-light mb-3 d-block"></i>
            <h4 class="text-muted">No events found matching your search.</h4>
            <button class="btn btn-link" @onclick='() => searchTerm = ""'>Clear filter</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ev in FilteredEvents)
            {
                <div class="col-md-6 col-lg-4">
                    <EventCard Event="ev" />
                </div>
            }
        </div>
    }
</div>

@code {
    private string searchTerm = "";
    private List<Event> allEvents = new();

    private List<Event> FilteredEvents => string.IsNullOrWhiteSpace(searchTerm)
        ? allEvents
        : allEvents.Where(e => e.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                               e.Location.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        // Generating mock data for demonstration
        allEvents = Enumerable.Range(1, 50).Select(i => new Event
        {
            Id = i,
            Name = i % 2 == 0 ? $"Tech Workshop #{i}" : $"Music Festival #{i}",
            Location = i % 3 == 0 ? "New York" : i % 3 == 1 ? "London" : "San Francisco",
            Date = DateTime.Now.AddDays(i),
            Description = "This is a comprehensive event description that demonstrates performance and two-way data binding."
        }).ToList();
    }
}