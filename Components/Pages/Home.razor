@page "/"

<PageTitle>EventEase - Modern Event Management</PageTitle>

<div class="container py-5 text-center animate-fade-in">
    <h1 class="display-3 fw-bold mb-3">
        Manage Your Events with <span class="gradient-text">EventEase</span>
    </h1>
    <p class="lead text-muted mb-5 mx-auto" style="max-width: 700px;">
        The all-in-one platform for corporate and social event management. Seamlessly browse, register, and track attendance for all your events.
    </p>
    
    <div class="d-flex justify-content-center gap-3">
        <a href="events" class="btn btn-primary btn-lg px-5">Browse Events</a>
        <a href="register" class="btn btn-outline-secondary btn-lg px-5">Join Now</a>
    </div>

    <div class="row mt-5 pt-5">
        <div class="col-md-4">
            <div class="p-4">
                <div class="h1 text-primary mb-3"><i class="bi bi-calendar-check"></i></div>
                <h4>Easy Scheduling</h4>
                <p class="text-muted">Plan and manage dates with our intuitive calendar interface.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4">
                <div class="h1 text-primary mb-3"><i class="bi bi-people"></i></div>
                <h4>Attendance Tracker</h4>
                <p class="text-muted">Keep track of every participant in real-time.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4">
                <div class="h1 text-primary mb-3"><i class="bi bi-shield-check"></i></div>
                <h4>Secure Data</h4>
                <p class="text-muted">Your event and user data is always safe with us.</p>
            </div>
        </div>
    </div>
</div>
