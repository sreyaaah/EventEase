@page "/"

<PageTitle>EventEase | Premium Event Management</PageTitle>

<div class="container-fluid px-0">
    <!-- Hero Section -->
    <section class="hero-section min-vh-100 d-flex align-items-center position-relative overflow-hidden">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 reveal-up">
                    <h1 class="display-1 fw-bold mb-4">
                        Transform Your <br />
                        <span class="gradient-text">Experiences.</span>
                    </h1>
                    <p class="lead text-muted mb-5 fs-4" style="max-width: 550px;">
                        EventEase is the next-generation platform for managing high-impact events. Seamless, beautiful, and powerful.
                    </p>
                    <div class="d-flex gap-4">
                        <a href="events" class="btn btn-premium btn-lg">Explore Events</a>
                        <a href="portfolio" class="btn btn-outline-light btn-lg rounded-pill px-4">View Portfolio</a>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="position-relative">
                        <!-- Floating Glass Card -->
                        <div class="premium-card p-5 animate-float ms-5" style="max-width: 400px; border-radius: 40px;">
                            <div class="badge bg-primary mb-3">Live Now</div>
                            <h3 class="mb-3">Tech Summit 2026</h3>
                            <p class="text-muted">Join the global community of innovators and creators.</p>
                            <div class="d-flex align-items-center mt-4">
                                <div class="avatar-group d-flex me-3">
                                    <div class="rounded-circle bg-secondary" style="width: 32px; height: 32px; border: 2px solid #0f172a;"></div>
                                    <div class="rounded-circle bg-primary" style="width: 32px; height: 32px; border: 2px solid #0f172a; margin-left: -10px;"></div>
                                    <div class="rounded-circle bg-info" style="width: 32px; height: 32px; border: 2px solid #0f172a; margin-left: -10px;"></div>
                                </div>
                                <span class="small text-muted">+1.2k attending</span>
                            </div>
                        </div>
                        <!-- Background Glow -->
                        <div class="position-absolute top-50 start-50 translate-middle" style="width: 400px; height: 400px; background: var(--primary); filter: blur(150px); opacity: 0.2; z-index: -1;"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="premium-card p-4 text-center">
                        <h2 class="fw-bold gradient-text mb-1">500+</h2>
                        <p class="text-muted mb-0">Events Hosted</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-card p-4 text-center">
                        <h2 class="fw-bold gradient-text mb-1">10k+</h2>
                        <p class="text-muted mb-0">Active Users</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-card p-4 text-center">
                        <h2 class="fw-bold gradient-text mb-1">99%</h2>
                        <p class="text-muted mb-0">Satisfaction</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    .hero-section {
        padding-top: 80px;
    }
</style>
