@page "/notfound"

<PageTitle>404 - Page Not Found</PageTitle>

<div class="container py-5 text-center animate-fade-in">
    <div class="glass-card p-5 mx-auto" style="max-width: 500px;">
        <h1 class="display-1 fw-bold gradient-text mb-0">404</h1>
        <h3 class="mb-4">Page Not Found</h3>
        <p class="text-muted mb-5">
            Oops! The page you are looking for doesn't exist or has been moved to a new event location.
        </p>
        <a href="/" class="btn btn-primary px-5 py-2">
            Back to Home
        </a>
    </div>
</div>