@inherits LayoutComponentBase

<div class="page dark-theme">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-bar d-md-none p-3 d-flex justify-content-between align-items-center">
            <span class="gradient-text fw-bold fs-4">EventEase</span>
            <button class="btn text-white" onclick="document.querySelector('.sidebar').classList.toggle('show')">
                <i class="bi bi-list fs-2"></i>
            </button>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    .dark-theme {
        display: flex;
        min-height: 100vh;
        background: #0f172a;
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .content {
        flex: 1;
        padding: 0;
        overflow-y: auto;
    }

    .sidebar {
        width: 280px;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(20px);
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        z-index: 1000;
    }

    @@media (max-width: 767.98px) {
        .sidebar {
            position: fixed;
            left: -280px;
            height: 100vh;
            transition: 0.3s;
        }
        .sidebar.show {
            left: 0;
        }
        .dark-theme {
            flex-direction: column;
        }
    }
</style>
